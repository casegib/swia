<form class="swia-sheet item-sheet heroability-sheet" autocomplete="off">
  <header class="sheet-header heroability-header">
    <div class="header-fields">
      {{#if editMode}}
      <input class="item-name-input" type="text" name="name" value="{{item.name}}" placeholder="{{localize 'SWIA.HeroAbility.NamePlaceholder'}}" />
      {{else}}
      <h1 class="item-name">{{item.name}}</h1>
      {{/if}}
      {{#if isGM}}
      <label class="edit-toggle-label">
        <input type="checkbox" data-action="toggleEdit" {{#if editMode}}checked{{/if}} />
        {{localize "SWIA.EditMode"}}
      </label>
      {{/if}}
    </div>
  </header>

  <section class="sheet-body">
    {{#if editMode}}
    <div class="form-group">
      <label>{{localize "SWIA.HeroAbility.AbilityText"}}</label>
      <textarea name="system.abilityText" rows="10" placeholder="{{localize 'SWIA.HeroAbility.AbilityTextPlaceholder'}}">{{systemData.abilityText}}</textarea>
    </div>
    <div class="form-group save-group">
      <button type="button" class="save-btn" data-action="saveItem">{{localize "SWIA.SaveChanges"}}</button>
    </div>
    {{else}}
    <div class="hero-ability-view">
      {{#if systemData.abilityText}}
      <div class="editor"><div class="editor-content hero-ability-description">{{{enrichedAbilityText}}}</div></div>
      {{else}}
      <p class="list-empty">{{localize "SWIA.HeroAbility.NoText"}}</p>
      {{/if}}
    </div>
    {{/if}}
  </section>
</form>
