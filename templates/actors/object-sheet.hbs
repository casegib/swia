<form class="swia-sheet type-object {{#if editMode}}editing{{/if}}" autocomplete="off">
  <div class="sheet-body">
    <div class="sheet-main">
      <header class="sheet-header">
        {{#if isGM}}
        <div class="edit-toggle">
          <label for="edit-mode">{{localize "SWIA.EditMode"}}</label>
          <input id="edit-mode" type="checkbox" data-action="toggleEdit" {{#if editMode}}checked{{/if}} />
        </div>
        {{/if}}

        <div class="image-section">
          <div class="image-container {{#if editMode}}editing{{/if}}">
            <img class="profile-image {{#if editMode}}clickable{{/if}}" src="{{profileSrc}}" {{#if editMode}}data-action="editImage" data-path="img"{{/if}} title="{{actor.name}}" />
            <img class="token-image {{#if editMode}}clickable{{/if}}" src="{{tokenPreviewSrc}}" {{#if editMode}}data-action="editImage" data-path="prototypeToken.texture.src"{{/if}} title="Token" />
          </div>
        </div>

        <div class="header-fields">
          <div class="name-row">
            <h1 class="actor-name">
              {{#if editMode}}
              <input type="text" name="name" value="{{actor.name}}" placeholder="{{localize "SWIA.Object.NamePlaceholder"}}" />
              {{else}}
              {{actor.name}}
              {{/if}}
            </h1>
          </div>
          <div class="biography-section">
            <label>{{localize "SWIA.Biography"}}</label>
            {{#if editMode}}
            <textarea name="system.biography" class="biography-input" rows="4">{{systemData.biography}}</textarea>
            <span class="editor-hint">{{localize "SWIA.BiographyHint"}}</span>
            {{else}}
            <div class="biography-display">{{{systemData.biography}}}</div>
            {{/if}}
          </div>
        </div>
      </header>

      <div class="sheet-content">
        <section class="resource-grid">
          <div class="stat-chips-row">
            <div class="resource">
              <label>{{localize "SWIA.Object.ObjectType"}}</label>
              <input type="text" name="system.objectType" value="{{systemData.objectType}}" placeholder="{{localize "SWIA.Object.ObjectTypePlaceholder"}}" {{#unless editMode}}disabled{{/unless}} />
            </div>
            <div class="resource">
              <label>{{localize "SWIA.Object.Traits"}}</label>
              <input type="text" name="system.traits" value="{{systemData.traits}}" placeholder="{{localize "SWIA.Object.TraitsPlaceholder"}}" {{#unless editMode}}disabled{{/unless}} />
            </div>
            <div class="resource">
              <label>{{localize "SWIA.Object.State"}}</label>
              <input type="text" name="system.objectState" value="{{systemData.objectState}}" placeholder="{{localize "SWIA.Object.StatePlaceholder"}}" {{#unless editMode}}disabled{{/unless}} />
            </div>
          </div>

          <div class="stat-chips-row">
            <div class="resource">
              <label>{{localize "SWIA.Attributes.Health"}}</label>
              {{#if editMode}}
              <div class="pair">
                <input name="system.attributes.health.value" type="number" min="0" value="{{currentAttributes.health.value}}" />
                <span>/</span>
                <input name="system.attributes.health.max" type="number" min="0" value="{{currentAttributes.health.max}}" />
              </div>
              {{else}}
              <input type="number" value="{{currentAttributes.health.value}}" disabled />
              {{/if}}
            </div>
            <div class="resource">
              {{#if editMode}}
              <label>{{localize "SWIA.Attributes.Defense"}}</label>
              <div class="defense">
                <label>{{localize "SWIA.Defense.Black"}}</label>
                <input name="system.attributes.defense.black" type="number" min="0" value="{{currentAttributes.defense.black}}" />
                <label>{{localize "SWIA.Defense.White"}}</label>
                <input name="system.attributes.defense.white" type="number" min="0" value="{{currentAttributes.defense.white}}" />
              </div>
              {{else}}
              <div class="attribute-row">
                <label class="dice-attr-label">{{localize "SWIA.Attributes.Defense"}}</label>
                <div class="dice-display">
                  <div class="dice-blocks">
                    {{#each defenseBlackDice}}
                    <span class="dice-block black"></span>
                    {{/each}}
                    {{#each defenseWhiteDice}}
                    <span class="dice-block white"></span>
                    {{/each}}
                  </div>
                </div>
              </div>
              {{/if}}
            </div>
          </div>
        </section>

        <section class="object-interaction">
          <div class="interactable-toggle">
            <label for="interactable">{{localize "SWIA.Object.Interactable"}}</label>
            <input id="interactable" type="checkbox" name="system.interactable" {{#if systemData.interactable}}checked{{/if}} {{#unless editMode}}disabled{{/unless}} />
            {{#if editMode}}
            <span class="editor-hint">{{localize "SWIA.Object.InteractableHint"}}</span>
            {{/if}}
          </div>

          {{#if systemData.interactable}}
          <div class="interaction-section">
            <label>{{localize "SWIA.Object.InteractionText"}}</label>
            {{#if editMode}}
            <textarea name="system.interactionText" class="biography-input" rows="3">{{systemData.interactionText}}</textarea>
            <span class="editor-hint">{{localize "SWIA.Object.InteractionTextHint"}}</span>
            {{else}}
            <div class="biography-display">{{{systemData.interactionText}}}</div>
            {{/if}}
          </div>
          {{/if}}
        </section>
      </div>
    </div>
  </div>
</form>
